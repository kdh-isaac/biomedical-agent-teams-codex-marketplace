{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Workflow Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "alias",
    "mode",
    "plugin_version",
    "execution_strategy",
    "nested_spawn_allowed",
    "spawned_review_lanes",
    "team_spawn_lanes",
    "stages",
    "final_label",
    "downgrade_reasons"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "alias": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["quick", "standard", "deep", "audit", "plan", "run"]
    },
    "plugin_version": { "type": "string" },
    "execution_strategy": {
      "type": "string",
      "enum": [
        "inline_only",
        "inline_first_selective_review",
        "team_level_selective_dag",
        "user_requested_full_spawn",
        "blocked"
      ]
    },
    "nested_spawn_allowed": { "type": "boolean" },
    "spawned_review_lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "status", "rationale", "ledger_handoff"],
        "properties": {
          "role": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "complete", "skipped", "blocked"]
          },
          "rationale": { "type": "string" },
          "ledger_handoff": { "type": "string" }
        }
      }
    },
    "team_spawn_lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["team", "phase", "depends_on", "status", "nested_spawn_used", "ledger_handoff"],
        "properties": {
          "team": { "type": "string" },
          "phase": { "type": "integer", "minimum": 0 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "complete", "skipped", "blocked"]
          },
          "nested_spawn_used": { "type": "boolean" },
          "ledger_handoff": { "type": "string" }
        }
      }
    },
    "team_output_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "team",
          "phase",
          "artifact_id",
          "path",
          "status",
          "checks_run",
          "ledger_handoff",
          "depends_on_outputs"
        ],
        "properties": {
          "team": { "type": "string" },
          "phase": { "type": "integer", "minimum": 0 },
          "artifact_id": { "type": "string" },
          "path": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "complete", "skipped", "blocked", "failed"]
          },
          "started_at": { "type": "string" },
          "completed_at": { "type": "string" },
          "input_scope": { "type": "string" },
          "checks_run": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ledger_handoff": { "type": "string" },
          "depends_on_outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "failure_or_downgrade_reason": { "type": "string" }
        }
      }
    },
    "spawned_agent_instances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "instance_id",
          "agent_id",
          "execution_surface",
          "status",
          "input_scope",
          "output_artifact",
          "checks_run",
          "ledger_handoff"
        ],
        "properties": {
          "instance_id": { "type": "string" },
          "agent_id": { "type": "string" },
          "execution_surface": {
            "type": "string",
            "enum": ["spawned_subagent", "tool_backed_validator", "external_verifier", "human_reviewer"]
          },
          "spawn_tool": { "type": "string" },
          "thread_or_task_id": { "type": "string" },
          "parent_run_id": { "type": "string" },
          "parent_instance_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "complete", "skipped", "blocked", "failed"]
          },
          "started_at": { "type": "string" },
          "completed_at": { "type": "string" },
          "input_scope": { "type": "string" },
          "output_artifact": { "type": "string" },
          "checks_run": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ledger_handoff": { "type": "string" },
          "failure_or_downgrade_reason": { "type": "string" }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "status", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "required": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["pass", "pass-with-caveats", "skipped", "block", "not-applicable"]
          },
          "evidence": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "block_condition": { "type": "string" }
        }
      }
    },
    "final_label": {
      "type": "string",
      "enum": [
        "Full protocol followed",
        "Contract-shaped artifact bundle",
        "Compact standard workflow",
        "Biomedical Agent Teams-informed narrative review",
        "Limited capability-downgraded workflow",
        "Partial workflow; formal gates skipped",
        "Blocked"
      ]
    },
    "downgrade_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts_root": { "type": "string" },
    "resume_pointer": { "type": "string" }
  }
}
