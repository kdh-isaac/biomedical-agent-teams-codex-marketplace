{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Workflow Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "alias",
    "mode",
    "plugin_version",
    "execution_strategy",
    "nested_spawn_allowed",
    "spawned_review_lanes",
    "team_spawn_lanes",
    "stages",
    "final_label",
    "downgrade_reasons"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "alias": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["quick", "standard", "deep", "audit", "plan", "run"]
    },
    "plugin_version": { "type": "string" },
    "execution_strategy": {
      "type": "string",
      "enum": [
        "inline_only",
        "inline_first_selective_review",
        "team_level_selective_dag",
        "user_requested_full_spawn",
        "blocked"
      ]
    },
    "nested_spawn_allowed": { "type": "boolean" },
    "spawned_review_lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "status", "rationale", "ledger_handoff"],
        "properties": {
          "role": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "complete", "skipped", "blocked"]
          },
          "rationale": { "type": "string" },
          "ledger_handoff": { "type": "string" }
        }
      }
    },
    "team_spawn_lanes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["team", "phase", "depends_on", "status", "nested_spawn_used", "ledger_handoff"],
        "properties": {
          "team": { "type": "string" },
          "phase": { "type": "integer", "minimum": 0 },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "status": {
            "type": "string",
            "enum": ["planned", "running", "complete", "skipped", "blocked"]
          },
          "nested_spawn_used": { "type": "boolean" },
          "ledger_handoff": { "type": "string" }
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "status", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "required": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["pass", "pass-with-caveats", "skipped", "block", "not-applicable"]
          },
          "evidence": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "block_condition": { "type": "string" }
        }
      }
    },
    "final_label": {
      "type": "string",
      "enum": [
        "Full protocol followed",
        "Compact standard workflow",
        "Biomedical Agent Teams-informed narrative review",
        "Partial workflow; formal gates skipped",
        "Blocked"
      ]
    },
    "downgrade_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts_root": { "type": "string" },
    "resume_pointer": { "type": "string" }
  }
}
