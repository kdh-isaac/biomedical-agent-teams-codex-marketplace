{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Preflight Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "requested_alias",
    "selected_mode",
    "deliverable_type",
    "evidence_scope",
    "risk_class",
    "required_role_outputs",
    "skipped_role_outputs_with_reason",
    "external_tools_allowed",
    "file_write_plan",
    "stop_criteria",
    "checkpoint_plan",
    "execution_strategy",
    "spawned_review_plan",
    "team_spawn_plan",
    "all_role_spawn_avoidance_reason",
    "nested_spawn_policy",
    "post_team_audit_plan"
  ],
  "properties": {
    "runtime_capability_preflight_id": {
      "type": "string"
    },
    "requested_alias": {
      "type": "string"
    },
    "selected_mode": {
      "type": "string",
      "enum": ["quick", "standard", "deep", "audit", "plan", "run"]
    },
    "deliverable_type": {
      "type": "string"
    },
    "evidence_scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source_types", "species_or_model", "date_or_version_needs"],
      "properties": {
        "source_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "species_or_model": {
          "type": "string"
        },
        "date_or_version_needs": {
          "type": "string"
        }
      }
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "moderate", "high"]
    },
    "required_role_outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skipped_role_outputs_with_reason": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "reason"],
        "properties": {
          "role": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "external_tools_allowed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "limits"],
      "properties": {
        "allowed": { "type": "boolean" },
        "limits": { "type": "string" }
      }
    },
    "file_write_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["will_write_files", "allowed_paths"],
      "properties": {
        "will_write_files": { "type": "boolean" },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "stop_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checkpoint_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkpoint", "required_before"],
        "properties": {
          "checkpoint": { "type": "string" },
          "required_before": { "type": "string" }
        }
      }
    },
    "execution_strategy": {
      "type": "string",
      "enum": [
        "inline_only",
        "inline_first_selective_review",
        "team_level_selective_dag",
        "user_requested_full_spawn",
        "blocked"
      ]
    },
    "spawned_review_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "budget", "selected_roles", "rationale"],
      "properties": {
        "allowed": { "type": "boolean" },
        "budget": { "type": "integer", "minimum": 0 },
        "selected_roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "type": "string" }
      }
    },
    "team_spawn_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "budget",
        "selected_teams",
        "dependency_graph",
        "nested_spawn_allowed",
        "rationale"
      ],
      "properties": {
        "allowed": { "type": "boolean" },
        "budget": { "type": "integer", "minimum": 0 },
        "selected_teams": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "biomedical-research-council",
              "idea-discovery-team",
              "omics-analysis-team",
              "evidence-audit-team",
              "experiment-design-team",
              "translational-scout-team"
            ]
          }
        },
        "dependency_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["team", "phase", "depends_on", "purpose"],
            "properties": {
              "team": { "type": "string" },
              "phase": { "type": "integer", "minimum": 0 },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" }
              },
              "purpose": { "type": "string" }
            }
          }
        },
        "nested_spawn_allowed": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "all_role_spawn_avoidance_reason": {
      "type": "string"
    },
    "nested_spawn_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "authorization", "limits"],
      "properties": {
        "allowed": { "type": "boolean" },
        "authorization": { "type": "string" },
        "limits": { "type": "string" }
      }
    },
    "post_team_audit_plan": {
      "type": "string"
    },
    "source_corpus_id": {
      "type": "string"
    },
    "workflow_run_id": {
      "type": "string"
    }
  }
}
